{
  "name": "@spicavi/tauri-plugin-push-notifications",
  "version": "0.1.0",
  "description": "Push notifications for Tauri 2 apps — APNs device tokens on iOS, FCM on Android, with foreground-receive and tap events.",
  "license": "MIT",
  "author": "spicavi <avisaksham@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spicavi/tauri-plugin-push-notifications.git"
  },
  "bugs": {
    "url": "https://github.com/spicavi/tauri-plugin-push-notifications/issues"
  },
  "homepage": "https://github.com/spicavi/tauri-plugin-push-notifications#readme",
  "type": "module",
  "types": "./dist-js/index.d.ts",
  "main": "./dist-js/index.cjs",
  "module": "./dist-js/index.js",
  "exports": {
    "types": "./dist-js/index.d.ts",
    "import": "./dist-js/index.js",
    "require": "./dist-js/index.cjs"
  },
  "files": [
    "dist-js",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "tauri",
    "tauri-plugin",
    "push-notifications",
    "apns",
    "fcm",
    "ios",
    "android"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rollup -c",
    "check-types": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@tauri-apps/api": ">=2.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.9.6",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
