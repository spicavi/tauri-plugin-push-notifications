<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Android 13+: notifications need a runtime permission; merges into
         consumers so requestPermission() can prompt. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application>
        <!-- FCM delivery service; manifest-merges into consumers. -->
        <service
            android:name="app.tauri.pushnotifications.PushNotificationsService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>
</manifest>
